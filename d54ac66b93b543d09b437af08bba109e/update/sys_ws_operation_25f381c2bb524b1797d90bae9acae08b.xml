        <name>Submit Complaint</name>
        <operation_script><![CDATA[(function process(request, response) {
                var body = request.body.data;
                var processor = new x_2091449_manage_0.OmnichannelIntakeProcessor();
                var result = processor.processIntake(body);
                
                if (result.success) {
                    response.setStatus(result.is_new_case ? 201 : 200);
                    response.setBody(result);
                } else {
                    response.setStatus(400);
                    response.setBody({ success: false, error: 'Failed to process intake' });
                }
            })(request, response)]]></operation_script>
